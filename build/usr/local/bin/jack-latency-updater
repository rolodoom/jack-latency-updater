#!/usr/bin/env python3

import sys
import os
import gi

gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gio

APP_ID = "org.jack.latency.updater"

DEFAULT_LATENCY = "256"
DEFAULT_RATE = "48000"

CONFIG_DIR = os.path.expanduser("~/.config/pipewire/jack.conf.d")

CONFIG_FILE = os.path.join(
    CONFIG_DIR,
    "99-latency.conf",
)

VALID_LATENCIES = [
    "16",
    "32",
    "64",
    "128",
    "256",
    "512",
    "1024",
    "2048",
    "4096",
]

VALID_RATES = [
    "44100",
    "48000",
    "96000",
]


def ensure_config_dir():
    os.makedirs(CONFIG_DIR, exist_ok=True)


def validate_values(latency, rate):
    if latency not in VALID_LATENCIES:
        return False

    if rate not in VALID_RATES:
        return False

    return True


def write_config(latency, rate):
    ensure_config_dir()

    content = f"""jack.properties = {{
    node.latency = {latency}/{rate}
}}
"""

    with open(CONFIG_FILE, "w") as f:
        f.write(content)


def read_current_config():
    if not os.path.exists(CONFIG_FILE):
        return DEFAULT_LATENCY, DEFAULT_RATE

    try:
        with open(CONFIG_FILE, "r") as f:
            for line in f:
                line = line.strip()

                if "node.latency" in line and not line.startswith("#"):
                    value = line.split("=")[1].strip()

                    if "/" in value:
                        latency, rate = value.split("/", 1)
                        return latency.strip(), rate.strip()

    except Exception:
        pass

    return DEFAULT_LATENCY, DEFAULT_RATE


class LatencyApp(Gtk.Application):
    def __init__(self):
        super().__init__(
            application_id=APP_ID,
            flags=Gio.ApplicationFlags.FLAGS_NONE,
        )

        self.window = None

    def do_activate(self):
        if not self.window:
            self.build_ui()

        self.window.present()

    def build_ui(self):
        self.window = Gtk.ApplicationWindow(application=self)

        self.window.set_title("PipeWire JACK Latency Updater")

        self.window.set_default_size(420, 180)

        root_box = Gtk.Box(
            orientation=Gtk.Orientation.VERTICAL,
            spacing=12,
            margin_top=12,
            margin_bottom=12,
            margin_start=12,
            margin_end=12,
        )

        grid = Gtk.Grid(
            column_spacing=8,
            row_spacing=8,
        )

        grid.set_halign(Gtk.Align.CENTER)

        latency, rate = read_current_config()

        latency_label = Gtk.Label(
            label="Latency (samples):",
            halign=Gtk.Align.START,
        )

        self.latency_entry = Gtk.Entry()
        self.latency_entry.set_text(latency)

        rate_label = Gtk.Label(
            label="Sample Rate (Hz):",
            halign=Gtk.Align.START,
        )

        self.rate_entry = Gtk.Entry()
        self.rate_entry.set_text(rate)

        grid.attach(latency_label, 0, 0, 1, 1)
        grid.attach(self.latency_entry, 1, 0, 1, 1)

        grid.attach(rate_label, 0, 1, 1, 1)
        grid.attach(self.rate_entry, 1, 1, 1, 1)

        root_box.append(grid)

        self.info_label = Gtk.Label(
            label="",
            xalign=0,
        )

        self.info_label.set_wrap(True)

        root_box.append(self.info_label)

        button_box = Gtk.Box(
            orientation=Gtk.Orientation.HORIZONTAL,
            spacing=8,
        )

        button_box.set_halign(Gtk.Align.CENTER)

        update_button = Gtk.Button.new_with_label("Update Config")

        update_button.connect(
            "clicked",
            self.on_update_clicked,
        )

        button_box.append(update_button)

        quit_button = Gtk.Button.new_with_label("Quit")

        quit_button.connect(
            "clicked",
            lambda *_: self.quit(),
        )

        button_box.append(quit_button)

        root_box.append(button_box)

        self.window.set_child(root_box)

    def on_update_clicked(self, _button):
        latency = self.latency_entry.get_text().strip()
        rate = self.rate_entry.get_text().strip()

        if not latency:
            latency = DEFAULT_LATENCY

        if not rate:
            rate = DEFAULT_RATE

        if not validate_values(latency, rate):
            self.info_label.set_text("Invalid latency or sample rate.")
            return

        try:
            write_config(latency, rate)

            self.info_label.set_text(f"Configuration updated: " f"{latency}/{rate}")

        except Exception as e:
            self.info_label.set_text(f"Failed to write configuration: {e}")


def main(argv):
    app = LatencyApp()
    return app.run(argv)


if __name__ == "__main__":
    sys.exit(main(sys.argv))
